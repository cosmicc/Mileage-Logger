APP_NAME=Mileage Logger
APP_ENV=production
SECRET_KEY=change-me
LOCAL_TIMEZONE=America/Detroit
CREATE_TABLES_ON_STARTUP=false
LOG_LEVEL=info
WEB_LOGIN_USERNAME=admin
WEB_LOGIN_PASSWORD=change-web-login-password
WEB_SESSION_COOKIE_SECURE=true
WEB_LOGIN_MAX_ATTEMPTS=5
WEB_LOGIN_LOCKOUT_SECONDS=300

POSTGRES_DB=mileage_logger
POSTGRES_USER=mileage
POSTGRES_PASSWORD=change-postgres-password
DATABASE_URL=postgresql+psycopg://mileage:change-postgres-password@postgres:5432/mileage_logger

# OwnTracks HTTP protection. OwnTracks Android HTTP mode works best with Basic Auth.
OWNTRACKS_API_TOKEN=change-owntracks-token
OWNTRACKS_USERNAME=owntracks
OWNTRACKS_PASSWORD=change-owntracks-password
OWNTRACKS_SYNC_WAYPOINTS=true
OWNTRACKS_DEFAULT_SITE_RADIUS_M=150
AUTOMATIC_TRIP_PROCESSING_ENABLED=true
AUTOMATIC_TRIP_PROCESSING_INTERVAL_SECONDS=60
OWNTRACKS_PURGE_ENABLED=true
OWNTRACKS_LOCATION_RETENTION_DAYS=14
OWNTRACKS_WAYPOINT_DWELL_MINUTES=5
OWNTRACKS_TRAVEL_DISTANCE_M=50.0

# Optional MQTT ingestion.
MQTT_ENABLED=false
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC=owntracks/#

# Fuel price source configuration.
GAS_PRICE_STATE=MI
GAS_PRICE_BUFFER=0.50
GAS_PRICE_SOURCE=aaa_current
EIA_API_KEY=
EIA_SERIES_ID=
VEHICLE_MPG=25.0

# Optional Smartcar odometer mileage source.
SMARTCAR_ENABLED=false
SMARTCAR_MANAGEMENT_TOKEN=
SMARTCAR_API_POLLING_ENABLED=false
SMARTCAR_ACCESS_TOKEN=
SMARTCAR_CLIENT_ID=
SMARTCAR_CLIENT_SECRET=
SMARTCAR_TOKEN_URL=https://iam.smartcar.com/oauth2/token
SMARTCAR_SCOPE=read_odometer
SMARTCAR_VEHICLE_ID=
SMARTCAR_API_BASE_URL=https://api.smartcar.com/v2.0
SMARTCAR_ODOMETER_UNIT=km
SMARTCAR_TIMEOUT_SECONDS=20
SMARTCAR_RETRY_ATTEMPTS=3
SMARTCAR_RETRY_DELAY_SECONDS=2
SMARTCAR_AUTH_FAILURE_COOLDOWN_SECONDS=3600
SMARTCAR_WEBHOOK_MAX_BODY_BYTES=262144

LOG_DIR=/data/logs
HOST_LOG_DIR=/var/log/mileage-logger
LOGIN_FAILURE_LOG_PATH=/var/log/mileage-logger-login-failures.log
HTTP_PORT=80

# Optional web UI IP allowlist. Leave blank to allow all clients.
# API endpoints under /api/ remain reachable from any IP for OwnTracks.
# Example: WEB_ALLOWED_CIDRS=192.168.1.0/24,10.8.0.0/24,203.0.113.44/32
WEB_ALLOWED_CIDRS=

# Optional recurring gas snapshot settings for the gas-snapshot container.
GAS_SNAPSHOT_INTERVAL_SECONDS=86400
GAS_SNAPSHOT_RUN_ON_STARTUP=true

# Required Cloudflare Tunnel container token from the Cloudflare dashboard.
# The Compose stack will not start until this value is set.
CLOUDFLARED_TUNNEL_TOKEN=
CLOUDFLARED_LOG_LEVEL=info
CLOUDFLARED_METRICS=
CLOUDFLARED_TRANSPORT_PROTOCOL=auto
