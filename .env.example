APP_NAME=Mileage Logger
APP_ENV=local
SECRET_KEY=change-me
DATABASE_URL=postgresql+psycopg://mileage:mileage@localhost:5432/mileage_logger
CREATE_TABLES_ON_STARTUP=false

# OwnTracks HTTP protection. Set either an API token or Basic Auth credentials.
OWNTRACKS_API_TOKEN=
OWNTRACKS_USERNAME=
OWNTRACKS_PASSWORD=
OWNTRACKS_AUTO_CREATE_SITES=true
OWNTRACKS_DEFAULT_SITE_RADIUS_M=150
OWNTRACKS_STOP_MINUTES=10
OWNTRACKS_UNKNOWN_STOP_RADIUS_M=150
AUTOMATIC_TRIP_PROCESSING_ENABLED=true
AUTOMATIC_TRIP_PROCESSING_INTERVAL_SECONDS=60
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACES_RADIUS_M=100
GOOGLE_PLACES_AUTO_CREATE_SITES=true

# Optional MQTT ingestion.
MQTT_ENABLED=false
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC=owntracks/#

# Fuel price source configuration.
GAS_PRICE_STATE=MI
GAS_PRICE_BUFFER=0.50
GAS_PRICE_SOURCE=aaa_current
EIA_API_KEY=
EIA_SERIES_ID=
VEHICLE_MPG=25.0

REPORT_OUTPUT_DIR=reports
