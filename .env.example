APP_NAME=Mileage Logger
APP_ENV=local
SECRET_KEY=change-me
LOCAL_TIMEZONE=America/Detroit
DATABASE_URL=postgresql+psycopg://mileage:mileage@localhost:5432/mileage_logger
CREATE_TABLES_ON_STARTUP=false
LOG_LEVEL=info
WEB_LOGIN_USERNAME=
WEB_LOGIN_PASSWORD=
WEB_SESSION_COOKIE_SECURE=false

# OwnTracks HTTP protection. Set either an API token or Basic Auth credentials.
OWNTRACKS_API_TOKEN=
OWNTRACKS_USERNAME=
OWNTRACKS_PASSWORD=
OWNTRACKS_SYNC_WAYPOINTS=true
OWNTRACKS_DEFAULT_SITE_RADIUS_M=150
AUTOMATIC_TRIP_PROCESSING_ENABLED=true
AUTOMATIC_TRIP_PROCESSING_INTERVAL_SECONDS=60
OWNTRACKS_PURGE_ENABLED=true
OWNTRACKS_LOCATION_RETENTION_DAYS=14
OWNTRACKS_DRIVING_SPEED_MPH=10.0
OWNTRACKS_DRIVING_WINDOW_MINUTES=10

# Optional MQTT ingestion.
MQTT_ENABLED=false
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC=owntracks/#

# Fuel price source configuration.
GAS_PRICE_STATE=MI
GAS_PRICE_BUFFER=0.50
GAS_PRICE_SOURCE=aaa_current
EIA_API_KEY=
EIA_SERIES_ID=
VEHICLE_MPG=25.0

# Optional Smartcar odometer mileage source.
SMARTCAR_ENABLED=false
SMARTCAR_MANAGEMENT_TOKEN=
SMARTCAR_API_POLLING_ENABLED=false
SMARTCAR_ACCESS_TOKEN=
SMARTCAR_CLIENT_ID=
SMARTCAR_CLIENT_SECRET=
SMARTCAR_TOKEN_URL=https://iam.smartcar.com/oauth2/token
SMARTCAR_SCOPE=read_odometer
SMARTCAR_VEHICLE_ID=
SMARTCAR_API_BASE_URL=https://api.smartcar.com/v2.0
SMARTCAR_ODOMETER_UNIT=km
SMARTCAR_TIMEOUT_SECONDS=20
SMARTCAR_RETRY_ATTEMPTS=3
SMARTCAR_RETRY_DELAY_SECONDS=2
SMARTCAR_AUTH_FAILURE_COOLDOWN_SECONDS=3600
SMARTCAR_WEBHOOK_MAX_BODY_BYTES=262144

# Required Cloudflare Tunnel container token from the Cloudflare dashboard.
# The Compose stack will not start until this value is set.
CLOUDFLARED_TUNNEL_TOKEN=
CLOUDFLARED_LOG_LEVEL=info
CLOUDFLARED_METRICS=
CLOUDFLARED_TRANSPORT_PROTOCOL=auto
